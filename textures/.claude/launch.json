{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "textures",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path');const dir='/Users/lorenpolster/Library/CloudStorage/Dropbox/Claude/Projects/textures';http.createServer((req,res)=>{const f=path.join(dir,req.url==='/'?'index.html':req.url);const ext=path.extname(f);const types={'.html':'text/html','.js':'text/javascript','.css':'text/css','.png':'image/png'};fs.readFile(f,(err,data)=>{if(err){res.writeHead(404);res.end('Not found');}else{res.writeHead(200,{'Content-Type':types[ext]||'text/plain'});res.end(data);}});}).listen(3847,()=>console.log('Server running on http://localhost:3847'));"],
      "port": 3847
    }
  ]
}
